# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=knowops
POSTGRES_USER=knowops
POSTGRES_PASSWORD=knowops_dev

# DATABASE_URL is consumed by the Python code (SQLAlchemy)
DATABASE_URL=postgresql://knowops:knowops_dev@localhost:5432/knowops

# ── MinIO (used internally by Milvus — not accessed by app code) ─
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Milvus ───────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ── Ollama ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── OpenRouter (LLM agents — Phase 3 of build order) ─────────────
# Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── Pipeline tuning ───────────────────────────────────────────────
# Freshness scoring (semantic vs recency weights, decay, date awareness)
# now lives in configs/pipeline.yaml as per-intent profiles selected by the
# Planner's time_sensitivity classification. Override the file path here:
PIPELINE_CONFIG=configs/pipeline.yaml

# Offline mode: 1 = no external services. Uses deterministic lexical
# embeddings, an in-memory brute-force vector search, and stubbed LLM agents
# so the demo and full test suite run with zero infrastructure.
# Leave 0 to use the real Milvus + Ollama + OpenRouter stack on the server.
KNOWOPS_OFFLINE=0

# Default time_sensitivity profile when the Planner is unsure (high|medium|low)
DEFAULT_TIME_SENSITIVITY=medium

# A document older than this many days triggers a freshness warning in answers
FRESHNESS_WARNING_DAYS=180

# Number of Milvus candidates fetched before reranking
RETRIEVER_TOP_K=20

# Number of reranked documents sent to the Answering Agent
RERANKER_TOP_K=5

# Documents embedded per Ollama call (do not exceed 8 with bge-m3 on 32 GB)
EMBEDDING_BATCH_SIZE=8

# Log level for the pipeline (DEBUG / INFO / WARNING / ERROR)
PIPELINE_LOG_LEVEL=INFO
